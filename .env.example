# API Configuration — single FastAPI backend.
VITE_API_URL=http://localhost:8000/api/v1

# OAuth Providers
VITE_GOOGLE_CLIENT_ID=your-google-client-id

# Feature Flags
VITE_ENABLE_OAUTH=true
VITE_ENABLE_AUTO_FILL=true
VITE_ENABLE_MANUAL_MODE=true

# Upload Settings
VITE_MAX_FILE_SIZE_MB=50
VITE_ALLOWED_FILE_TYPES=pdf,png,jpg,jpeg,tiff

# App Settings
VITE_APP_NAME=AI Document Signer
VITE_APP_VERSION=1.0.0
